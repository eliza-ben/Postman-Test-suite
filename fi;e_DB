async def read_csv_file(file_config: FileConfig) -> List[Dict[str, Any]]:
    """Read CSV/TSV file and return list of dictionaries.

    Supports both single-character and multi-character delimiters (e.g., '||', '::').
    """
    records = []
    file_path = Path(file_config.file_path)

    if not file_path.exists():
        raise HTTPException(status_code=400, detail=f"File not found: {file_config.file_path}")

    # Determine delimiter
    delimiter = file_config.delimiter
    if not delimiter:
        delimiter = "," if file_config.file_type == "csv" else "\t"

    # Open file (with gzip if compressed)
    if file_config.compressed:
        file_handle = gzip.open(file_path, 'rt', encoding=file_config.encoding)
    else:
        file_handle = open(file_path, 'r', encoding=file_config.encoding)

    try:
        # Read all lines for skip_lines and skip_footer_lines support
        all_lines = file_handle.readlines()

        # Skip header lines (before actual header row)
        if file_config.skip_lines > 0:
            all_lines = all_lines[file_config.skip_lines:]

        # Skip footer lines
        if file_config.skip_footer_lines > 0:
            all_lines = all_lines[:-file_config.skip_footer_lines]

        if not all_lines:
            return records

        # Check if delimiter is multi-character (csv module only supports single char)
        if len(delimiter) > 1:
            # Multi-character delimiter: manual parsing
            # Parse header or generate column names
            if file_config.has_header:
                header_line = all_lines[0].rstrip('\r\n')
                headers = header_line.split(delimiter)
                data_lines = all_lines[1:]
            else:
                # Generate column names from first line
                first_line = all_lines[0].rstrip('\r\n')
                num_cols = len(first_line.split(delimiter))
                headers = [f"col_{i}" for i in range(num_cols)]
                data_lines = all_lines

            # Parse data lines
            for line in data_lines:
                line = line.rstrip('\r\n')
                if not line:
                    continue
                values = line.split(delimiter)
                record = {headers[i]: values[i] if i < len(values) else '' for i in range(len(headers))}
                records.append(record)
        else:
            # Single-character delimiter: use csv module on remaining lines
            import io
            remaining_content = ''.join(all_lines)
            text_stream = io.StringIO(remaining_content)

            reader = csv.DictReader(text_stream, delimiter=delimiter) if file_config.has_header else csv.reader(text_stream, delimiter=delimiter)

            if file_config.has_header:
                for row in reader:
                    records.append(dict(row))
            else:
                # Generate column names: col_0, col_1, col_2, ...
                for row in reader:
                    record = {f"col_{i}": value for i, value in enumerate(row)}
                    records.append(record)
    finally:
        file_handle.close()

    logger.info(f"Read {len(records)} records from {file_config.file_path} (delimiter: '{delimiter}', skip_lines: {file_config.skip_lines}, skip_footer: {file_config.skip_footer_lines})")
    return records


async def read_json_file(file_config: FileConfig) -> List[Dict[str, Any]]:
    """Read JSON file and return list of dictionaries."""
    file_path = Path(file_config.file_path)

    if not file_path.exists():
        raise HTTPException(status_code=400, detail=f"File not found: {file_config.file_path}")

    # Open file (with gzip if compressed)
    if file_config.compressed:
        file_handle = gzip.open(file_path, 'rt', encoding=file_config.encoding)
    else:
        file_handle = open(file_path, 'r', encoding=file_config.encoding)

    try:
        data = json.load(file_handle)

        # Extract data using JSONPath if specified
        if file_config.json_path:
            from jsonpath_ng import parse
            jsonpath_expr = parse(file_config.json_path)
            matches = [match.value for match in jsonpath_expr.find(data)]
            if matches:
                data = matches[0] if len(matches) == 1 else matches

        # Ensure data is a list
        if isinstance(data, dict):
            return [data]
        elif isinstance(data, list):
            return data
        else:
            raise HTTPException(status_code=400, detail="JSON data must be an object or array")
    finally:
        file_handle.close()


async def read_fixed_width_file(file_config: FileConfig) -> List[Dict[str, Any]]:
    """Read fixed-width file and return list of dictionaries."""
    records = []
    file_path = Path(file_config.file_path)

    if not file_path.exists():
        raise HTTPException(status_code=400, detail=f"File not found: {file_config.file_path}")

    if not file_config.field_widths:
        raise HTTPException(status_code=400, detail="field_widths required for fixed-width files")

    # Open file (with gzip if compressed)
    if file_config.compressed:
        file_handle = gzip.open(file_path, 'rt', encoding=file_config.encoding)
    else:
        file_handle = open(file_path, 'r', encoding=file_config.encoding)

    try:
        lines = file_handle.readlines()

        # Get field names from header or use provided names
        if file_config.has_header and lines:
            header_line = lines[0].strip()
            # Parse header using field widths
            field_names = []
            start = 0
            for width in file_config.field_widths:
                field_name = header_line[start:start+width].strip()
                field_names.append(field_name)
                start += width
            lines = lines[1:]  # Skip header
        elif file_config.field_names:
            field_names = file_config.field_names
        else:
            # Generate column names: col_0, col_1, col_2, ...
            field_names = [f"col_{i}" for i in range(len(file_config.field_widths))]

        # Parse data lines
        for line in lines:
            if not line.strip():
                continue

            record = {}
            start = 0
            for i, width in enumerate(file_config.field_widths):
                value = line[start:start+width].strip()
                record[field_names[i]] = value
                start += width

            records.append(record)
    finally:
        file_handle.close()

    return records


async def read_excel_file(file_config: FileConfig) -> List[Dict[str, Any]]:
    """Read Excel file (.xlsx or .xls) and return list of dictionaries."""
    try:
        from openpyxl import load_workbook
    except ImportError:
        raise HTTPException(
            status_code=500,
            detail="Excel support requires openpyxl. Install with: pip install openpyxl"
        )

    file_path = Path(file_config.file_path)
    if not file_path.exists():
        raise HTTPException(status_code=404, detail=f"File not found: {file_config.file_path}")

    wb = load_workbook(filename=str(file_path), read_only=True, data_only=True)

    # Get the worksheet (first sheet or specified sheet)
    sheet_name = file_config.sheet_name
    if sheet_name:
        if sheet_name not in wb.sheetnames:
            raise HTTPException(
                status_code=400,
                detail=f"Sheet '{sheet_name}' not found. Available: {wb.sheetnames}"
            )
        ws = wb[sheet_name]
    else:
        ws = wb.active
    
    records = []
    rows = list(ws.iter_rows(values_only=True))
    
    # Skip lines
    skip_lines = file_config.skip_lines or 0
    rows = rows[skip_lines:]
    
    if not rows:
        wb.close()
        return records
    
    # Determine field names
    if file_config.has_header:
        headers = [str(cell) if cell is not None else f"col_{i}" for i, cell in enumerate(rows[0])]
        data_rows = rows[1:]
    elif file_config.field_names:
        headers = file_config.field_names
        data_rows = rows
    else:
        headers = [f"col_{i}" for i in range(len(rows[0]))]
        data_rows = rows
    
    # Build records
    for row in data_rows:
        record = {}
        for i, value in enumerate(row):
            if i < len(headers):
                record[headers[i]] = value
        records.append(record)
    
    wb.close()
    logger.info(f"Read {len(records)} records from Excel file: {file_config.file_path}")
    return records


async def read_file(file_config: FileConfig) -> List[Dict[str, Any]]:
    """Read file based on file type."""
    logger.info(f"Reading file: {file_config.file_path} (type: {file_config.file_type})")
    
    if file_config.file_type in ["csv", "tsv"]:
        return await read_csv_file(file_config)
    elif file_config.file_type == "json":
        return await read_json_file(file_config)
    elif file_config.file_type == "fixed":
        return await read_fixed_width_file(file_config)
    elif file_config.file_type in ["xls", "xlsx", "excel"]:
        return await read_excel_file(file_config)
    else:
        raise HTTPException(status_code=400, detail=f"Unsupported file type: {file_config.file_type}")


