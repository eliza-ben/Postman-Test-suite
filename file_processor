"""File Processor - Reusable file I/O operations for ETL services."""

import csv
import gzip
import json
from typing import Any, Dict, List, Optional
from datetime import datetime
from pathlib import Path
from fastapi import HTTPException


class FileReader:
    """Read various file formats with compression support."""
    
    @staticmethod
    async def read_csv(
        file_path: str,
        encoding: str = "utf-8",
        delimiter: str = ",",
        has_header: bool = True,
        skip_lines: int = 0,
        skip_footer_lines: int = 0,
        field_names: Optional[List[str]] = None,
    ) -> List[Dict[str, Any]]:
        """
        Read CSV/TSV file with multi-character delimiter and footer skip support.
        
        Args:
            file_path: Path to file
            encoding: File encoding
            delimiter: Field delimiter (supports multi-char like '||', '::')
            has_header: Whether file has header row
            skip_lines: Number of lines to skip at start (before header)
            skip_footer_lines: Number of lines to skip at end (footer)
            field_names: Custom field names (if no header)
        
        Returns:
            List of records as dictionaries
        """
        records = []
        path = Path(file_path)
        
        if not path.exists():
            raise HTTPException(status_code=404, detail=f"Source file not found: {file_path}")
        
        # Handle gzip
        if file_path.endswith('.gz'):
            file_handle = gzip.open(path, 'rt', encoding=encoding)
        else:
            file_handle = open(path, 'r', encoding=encoding)
        
        try:
            # Read all lines for skip_lines and skip_footer_lines support
            all_lines = file_handle.readlines()
            
            # Skip header lines (before actual header row)
            if skip_lines > 0:
                all_lines = all_lines[skip_lines:]
            
            # Skip footer lines
            if skip_footer_lines > 0:
                all_lines = all_lines[:-skip_footer_lines]
            
            if not all_lines:
                return records
            
            # Check if delimiter is multi-character (csv module only supports single char)
            if len(delimiter) > 1:
                # Multi-character delimiter: manual parsing
                if has_header:
                    header_line = all_lines[0].rstrip('\r\n')
                    headers = header_line.split(delimiter)
                    data_lines = all_lines[1:]
                elif field_names:
                    headers = field_names
                    data_lines = all_lines
                else:
                    first_line = all_lines[0].rstrip('\r\n')
                    num_cols = len(first_line.split(delimiter))
                    headers = [f"col_{i}" for i in range(num_cols)]
                    data_lines = all_lines
                
                for line in data_lines:
                    line = line.rstrip('\r\n')
                    if not line:
                        continue
                    values = line.split(delimiter)
                    record = {headers[i]: values[i] if i < len(values) else '' for i in range(len(headers))}
                    records.append(record)
            else:
                # Single-character delimiter: use csv module
                import io
                remaining_content = ''.join(all_lines)
                text_stream = io.StringIO(remaining_content)
                
                reader = csv.DictReader(
                    text_stream,
                    delimiter=delimiter,
                    fieldnames=field_names if not has_header else None
                )
                
                for row in reader:
                    records.append(dict(row))
        
        finally:
            file_handle.close()
        
        return records
    
    @staticmethod
    async def read_json(
        file_path: str,
        encoding: str = "utf-8",
        skip_lines: int = 0,
        records_pointer: Optional[str] = "$",
    ) -> List[Dict[str, Any]]:
        """
        Read JSON file with optional JSONPath extraction.
        
        Preserves exact logic from file-to-file service.
        
        Args:
            file_path: Path to file
            encoding: File encoding
            skip_lines: Number of lines to skip
            records_pointer: JSONPath to extract records
        
        Returns:
            List of records
        """
        path = Path(file_path)
        
        if not path.exists():
            raise HTTPException(status_code=404, detail=f"Source file not found: {file_path}")
        
        if file_path.endswith('.gz'):
            file_handle = gzip.open(path, 'rt', encoding=encoding)
        else:
            file_handle = open(path, 'r', encoding=encoding)
        
        try:
            # Skip lines
            for _ in range(skip_lines):
                next(file_handle)
            
            data = json.load(file_handle)
            
            # Extract records using JSONPath if needed
            if records_pointer and records_pointer != "$":
                import jsonpath_ng
                path_expr = jsonpath_ng.parse(records_pointer)
                matches = path_expr.find(data)
                if matches:
                    data = matches[0].value
            
            if isinstance(data, list):
                return data
            else:
                return [data]
        
        finally:
            file_handle.close()
    
    @staticmethod
    async def read_jsonl(
        file_path: str,
        encoding: str = "utf-8",
        skip_lines: int = 0,
    ) -> List[Dict[str, Any]]:
        """
        Read JSON Lines file.
        
        Preserves exact logic from file-to-file service.
        
        Args:
            file_path: Path to file
            encoding: File encoding
            skip_lines: Number of lines to skip
        
        Returns:
            List of records
        """
        path = Path(file_path)
        
        if not path.exists():
