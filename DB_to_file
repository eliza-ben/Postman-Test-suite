async def export_to_file(
    engine: AsyncEngine,
    table: Table,
    req: ExportRequest,
    jolt_client: Optional[JoltClient],
) -> tuple[str, int]:
    """
    Export database to file using common processors.
    
    This function orchestrates the complete export process:
    1. Builds and executes database query with filters
    2. Streams data in batches for memory efficiency
    3. Applies ETL pipeline (mapping, JOLT, validation)
    4. Formats values (dates, decimals) for output
    5. Writes to file (CSV/TSV or fixed-width)
    6. Publishes audit events
    
    Args:
        engine: SQLAlchemy async database engine
        table: SQLAlchemy Table object (reflected from database)
        req: ExportRequest with complete configuration
        jolt_client: JOLT client for transformations (optional)
    
    Returns:
        Tuple of (output_file_path, total_records_exported)
    
    Raises:
        HTTPException: If export fails
    """
    # Build query
    source_cols = [mapping.source for mapping in req.mapping]
    for col in source_cols:
        validate_ident(col, "source column")
    
    columns = [table.c[col] for col in source_cols]
    query = select(*columns)
    
    # Convert FilterCondition models to dicts for QueryBuilder
    filter_dicts = [{"column": f.column, "op": f.op, "value": f.value} for f in req.filters]
    where_clause = QueryBuilder.build_where_clause(table, filter_dicts)
    if where_clause is not None:
        query = query.where(where_clause)
    
    # Generate filename
    timestamp = datetime.now().strftime("%Y%m%d_%H%M%S")
    logger.info(f"file type: {req.file.type}")
    if req.file.type == "delimited":
        ext = "csv" if req.file.delimiter == "," else "tsv"
    elif req.file.type == "xls":
        ext = "xlsx"
    elif req.file.type == "xlsx":
        ext = "xlsx"
    else:  # fixed
        ext = "txt"

    # Appending filename with correlation_Id based on correlation flag
    filename = f"{req.file.filename_prefix}_{get_correlation_id()}.{ext}" if req.file.include_correlation_id else f"{req.file.filename_prefix}.{ext}"

    if req.file.compress:
        filename += ".gz"

    # Fix for Snyk Code Report issues
    # output_path = Path(req.file.output_path)
    output_path = get_safe_file_path(BASE_DIR, req.file.output_path)

    logger.info(f"output_file_path: {output_path}")

    output_path.mkdir(parents=True, exist_ok=True)
    filepath = str(output_path / filename)
    
    # Stream, process, and collect all records
    all_records = []
    batch = []
    batch_count = 0
    
    logger.info(f"Starting data export from table: {table.name}")
    
    async with engine.connect() as conn:
        result = await conn.stream(query)
        
        async for row in result:
            row_dict = {source_cols[i]: row[i] for i in range(len(source_cols))}
            
            # Convert database-specific objects to strings for Avro compatibility
            import datetime as dt
            import decimal
            import uuid
            import json
            
            for key, value in row_dict.items():
                if value is None:
                    continue  # Keep None values as-is
                
                try:
                    # Date and DateTime types
                    if isinstance(value, dt.date):
                        row_dict[key] = value.isoformat()  # Convert to YYYY-MM-DD string
                    elif isinstance(value, dt.datetime):
                        row_dict[key] = value.isoformat()  # Convert to ISO datetime string
                    elif isinstance(value, dt.time):
                        row_dict[key] = value.isoformat()  # Convert to HH:MM:SS string
                    elif isinstance(value, dt.timedelta):
                        row_dict[key] = str(value)  # Convert to string representation
                    
                    # Numeric types
                    elif isinstance(value, decimal.Decimal):
                        row_dict[key] = str(value)  # Preserve precision as string
                    
                    # UUID/GUID types
                    elif isinstance(value, uuid.UUID):
                        row_dict[key] = str(value)  # Convert to string representation
                    
                    # Binary data types
                    elif isinstance(value, (bytes, bytearray)):
                        try:
                            # Try to decode as UTF-8 first
                            row_dict[key] = value.decode('utf-8')
                        except UnicodeDecodeError:
                            # Fall back to base64 encoding for binary data
                            import base64
                            row_dict[key] = base64.b64encode(value).decode('ascii')
                            logger.debug(f"Converted binary field '{key}' to base64")
                    
                    # JSON/JSONB types (dict/list from database)
                    elif isinstance(value, (dict, list)):
                        row_dict[key] = json.dumps(value, ensure_ascii=False)
                    
                    # Array types (PostgreSQL arrays come as lists)
                    elif isinstance(value, tuple) and hasattr(value, '__iter__'):
                        row_dict[key] = json.dumps(list(value), ensure_ascii=False)
                    
                    # Enum types and other custom objects
                    elif hasattr(value, '__str__') and not isinstance(value, (str, int, float, bool)):
                        original_type = type(value).__name__
                        row_dict[key] = str(value)  # Convert custom objects to string
                        logger.debug(f"Converted field '{key}' from {original_type} to string: {row_dict[key]}")
                        
                except Exception as conversion_error:
                    # Log the error but continue processing
                    logger.warning(f"Failed to convert field '{key}' (type: {type(value).__name__}, value: {repr(value)}): {conversion_error}")
                    # Fall back to string conversion
                    try:
                        row_dict[key] = str(value)
                    except Exception:
                        # Last resort: set to None
                        row_dict[key] = None
                        logger.error(f"Could not convert field '{key}' at all, setting to None")
            
            batch.append(row_dict)
            
            if len(batch) >= req.fetch_batch_size:
                # Normalize column names for case-sensitive database compatibility
                batch = normalize_column_names_for_table(batch, table)
                batch_count += 1
                batch_start = time.time()
                
                # Audit: Records received from database
                await publish_audit_event(
                    domain_id=DEFAULT_DOMAIN_ID,
                    entity_type="TABLE",
                    entity_id=table.name,
                    event_type="RECORDS_READ",
                    outcome="SUCCESS",
                    details=f"Read {len(batch)} records from table (batch {batch_count})",
                    payload={"records_count": len(batch), "batch_number": batch_count},
                )
                
                # Format values BEFORE validation (only for date/decimal types that need formatting)
                for record in batch:
                    for mapping in req.mapping:
                        if mapping.source in record and mapping.format:
                            # Only format if a format string is specified
                            value = record[mapping.source]
                            formatted = ValueFormatter.format_value(value, mapping.type, mapping.format)
                            record[mapping.source] = formatted
                
                # Process batch using ETLPipeline with aggregation support
                mapping_dicts = [{"source": m.source, "target": m.target} for m in req.mapping]
                processed = await ETLPipeline.process_batch(
                    batch,
                    target_schema=req.target_avro_schema,  # Can be None
                    jolt_spec=req.jolt_spec,
                    mapping=mapping_dicts,
                    jolt_client=jolt_client,
                    aggregation_config=req.aggregation_config,  # 🆕 Aggregation support
                    expression_config=req.expression_config,  # 🆕 Expression evaluation support
                )
                
                # Audit: Records processed
                await publish_audit_event(
                    domain_id=DEFAULT_DOMAIN_ID,
                    entity_type="ETL_PIPELINE",
                    entity_id=f"{table.name}->file",
                    event_type="RECORDS_PROCESSED",
                    outcome="SUCCESS",
                    details=f"Processed {len(processed)} records (batch {batch_count})",
                    payload={"records_count": len(processed), "batch_number": batch_count, "has_jolt": req.jolt_spec is not None},
                )
                
                all_records.extend(processed)
                
                log_database_operation(
                    logger,
                    "read_batch",
                    table.name,
                    len(processed),
                    (time.time() - batch_start) * 1000,
                    batch_number=batch_count,
                    total_so_far=len(all_records),
                )
                
                batch = []
    
    # Process remaining
    if batch:
        # Normalize column names for case-sensitive database compatibility
        batch = normalize_column_names_for_table(batch, table)
        
        # Format values BEFORE validation (only for date/decimal types that need formatting)
        for record in batch:
            for mapping in req.mapping:
                if mapping.source in record and mapping.format:
                    # Only format if a format string is specified
                    value = record[mapping.source]
                    formatted = ValueFormatter.format_value(value, mapping.type, mapping.format)
                    record[mapping.source] = formatted
        
        mapping_dicts = [{"source": m.source, "target": m.target} for m in req.mapping]
        processed = await ETLPipeline.process_batch(
            batch,
            target_schema=None,  # Skip target validation until after aggregation
            jolt_spec=req.jolt_spec,
            mapping=mapping_dicts,
            jolt_client=jolt_client,
            aggregation_config=req.aggregation_config,  # 🆕 Aggregation support
            expression_config=req.expression_config,  # 🆕 Expression evaluation support
        )
        all_records.extend(processed)
    
    # Validate against target Avro schema AFTER all processing (including aggregation)
    if req.target_avro_schema and all_records:
        from common.avro import validate_batch_list, normalize_records_for_schema
        # Normalize union types for target schema compatibility
        all_records = normalize_records_for_schema(all_records, req.target_avro_schema)
        # Validate final data structure against target schema
        validate_batch_list(all_records, req.target_avro_schema)
    
    # Write to file using FileWriter
    # Determine field names based on configuration
    if req.aggregation_config and all_records:
        # Use actual column names from aggregated data
        available_fields = list(all_records[0].keys())
        
        # If target Avro schema is provided, use it to filter/order columns
        if req.target_avro_schema and "fields" in req.target_avro_schema:
            schema_fields = [field["name"] for field in req.target_avro_schema["fields"]]
            # Only include fields that exist in both schema and data
            field_names = [f for f in schema_fields if f in available_fields]
        else:
            field_names = available_fields
    else:
        # Use mapping target names for non-aggregated data
        field_names = list(all_records[0].keys()) if all_records else []

    if all_records:
        logger.info("Sample record before write: %s", all_records[0])
    if req.file.type == "delimited":
        written_path = await FileWriter.write_csv(
            all_records,
            filepath,
            field_names,
            encoding=req.file.encoding,
            delimiter=req.file.delimiter,
            quotechar=req.file.quotechar,
            header=req.file.header,
            compress=req.file.compress,
        )
    elif req.file.type in ("xls", "xlsx"):
        written_path = await FileWriter.write_excel(
            all_records,
            filepath,
            field_names,
            sheet_name=req.file.sheet_name,
            header=req.file.header,
        )
    else:  # fixed
        if req.aggregation_config:
            raise HTTPException(
                status_code=400,
                detail="Fixed-width format is not supported with aggregation. Use delimited format instead."
            )
        field_widths = [m.width for m in req.mapping]
        written_path = await FileWriter.write_fixed_width(
            all_records,
            filepath,
            field_names,
            field_widths,
            encoding=req.file.encoding,
            align=req.mapping[0].align if req.mapping else "left",
            pad_char=req.mapping[0].pad_char if req.mapping else " ",
            strict_width=req.file.strict_width,
            header=req.file.header,
            compress=req.file.compress,
        )
    
    return written_path, len(all_records)


