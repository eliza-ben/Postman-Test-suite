SAFE_PATH_PATTERN = re.compile(r'^[a-zA-Z0-9._\-/\\]+$')

def get_safe_file_path(base_dir: Path, user_input_path: str) -> Path:
    base_dir = base_dir.resolve()

    # Basic validation for illegal characters
    if not SAFE_PATH_PATTERN.match(user_input_path):
        raise HTTPException(status_code=400, detail="Invalid file path")

    # Prevent obvious traversal
    if ".." in user_input_path:
        raise HTTPException(status_code=400, detail="Path traversal detected")

    # Construct and normalize the path
    safe_path = (base_dir / user_input_path).resolve()

    # Ensure the resolved path stays inside BASE_DIR
    if base_dir not in safe_path.parents and safe_path != base_dir:
        raise HTTPException(status_code=400, detail="Access outside base directory is not allowed")

    return safe_path

