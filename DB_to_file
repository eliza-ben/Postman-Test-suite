@limiter.limit(STRICT_RATE_LIMIT)  # 10 requests per minute
async def export_dbtofile(
    request: Request,  # Required by SlowAPI for rate limiting
    req: ExportRequest,
    auth: Dict = Depends(verify_jwt_or_basic),
) -> ExportResponse:
    """
    Export database to file with full ETL pipeline.
    
    This is the main export endpoint that orchestrates the complete data flow from
    database to file with validation, transformation, formatting, and audit trail.
    
    Authentication:
    ---------------
    Requires JWT token or Basic authentication (verified by security gateway).
    The authenticated user/subject is included in audit events.
    
    Data Flow:
    ----------
    1. **Query Database**
       - Streaming query execution (memory-efficient)
       - WHERE clause filtering with 12 operators
       - Column selection based on mapping
    
    2. **Column Mapping**
       - Maps source columns to target fields
       - Applies default values for nulls
    
    3. **Transformation (Optional)**
       - Applies JOLT transformations if jolt_spec provided
       - Supports shift, default, remove, modify operations
    
    4. **Avro Validation (Optional)**
       - Validates transformed data against target_avro_schema (if provided)
       - Ensures data quality before file write
    
    5. **Value Formatting**
       - Date formatting (%Y-%m-%d, %m/%d/%Y, etc.)
       - Decimal formatting (%.2f, %.4f, etc.)
       - Type conversion
    
    6. **File Write**
       - CSV/TSV: Delimited output with headers
       - Fixed-Width: Positional data with alignment
       - Gzip compression (optional)
       - Custom encoding support
    
    7. **Audit Trail**
       - Publishes events to Kafka: records_received, records_processed,
         records_written
       - Full correlation ID tracking for data lineage
    
    File Naming:
    ------------
    Output files are automatically named with timestamp:
    - CSV: {prefix}_{timestamp}.csv
    - TSV: {prefix}_{timestamp}.tsv
    - Fixed: {prefix}_{timestamp}.txt
    - Compressed: {filename}.gz
    
    Performance:
    ------------
    - Batch processing: Configurable batch size (default: 10,000 records)
    - Throughput: 10,000-50,000 records/sec depending on database and format
    - Memory: Processes data in batches to minimize memory footprint
    
    Args:
        request: ExportRequest with complete ETL configuration
        auth: Authentication context (injected by dependency)
    
    Returns:
        ExportResponse with status, records, file path, and duration_ms
    
    Raises:
        HTTPException 400: Invalid request (schema validation, identifier validation)
        HTTPException 500: Export failure (database error, file write error)
    
    Example:
        See DB_TO_FILE_SPECIFICATION.md for complete request examples.
    """
    start_time = time.time()
    correlation_id = get_correlation_id()
    
    logger.info(
        f"Starting DB-to-File export: {req.db.table_name} -> {req.file.output_path}",
        extra={
            "extra_fields": {
                "source_table": req.db.table_name,
                "source_schema": req.db.schema_name,
                "output_path": req.file.output_path,
                "file_type": req.file.type,
                "auth_user": auth.get("username") or auth.get("subject"),
                "has_jolt": req.jolt_spec is not None,
            }
        }
    )
    
    # Audit: Operation started
    await publish_audit_event(
        domain_id=DEFAULT_DOMAIN_ID,
        entity_type="OPERATION",
        entity_id=f"{req.db.table_name}->{req.file.output_path}",
        event_type="OPERATION_STARTED",
        outcome="INFO",
        details=f"Starting DB-to-file export from {req.db.table_name} to {req.file.output_path}",
        payload={
            "operation_type": "db-to-file",
            "source": req.db.table_name,
            "destination": req.file.output_path,
            "correlation_id": correlation_id,
        },
        metadata={
            "correlation_id": correlation_id,
            "source": req.db.table_name,
            "destination": req.file.output_path,
        },
    )
    
    with OPERATION_LATENCY.labels(service=SERVICE_NAME, operation="export").time():
        try:
            # Validate identifiers
            validate_ident(req.db.table_name, "table name")
            if req.db.schema_name:
                validate_ident(req.db.schema_name, "schema name")
            
            logger.debug(f"Validated identifiers: table={req.db.table_name}, schema={req.db.schema_name}")
            
            # Create DB engine
            engine = async_engine(req.db.sqlalchemy_url)
            
            # Reflect table
            table = await reflect_table(
                engine,
                req.db.table_name,
                req.db.schema_name,
            )
            
            # Initialize JOLT client if needed
            jolt_client = JoltClient() if req.jolt_spec else None
            
            # Export to file
            logger.debug(f"About to call export_to_file with table: {table.name}")
            try:
                filepath, total_records = await export_to_file(
                    engine,
                    table,
                    req,
                    jolt_client,
                )
                logger.debug(f"export_to_file completed successfully: {filepath}, {total_records} records")
            except Exception as export_error:
                logger.error(f"export_to_file failed with error: {type(export_error).__name__}: {str(export_error)}")
                logger.debug(f"Full export error details: {export_error}", exc_info=True)
                raise
            
            # Audit: File written (already done below with publish_audit_event)
            
            # Cleanup
            await engine.dispose()
            
            # Metrics
            record_batch(SERVICE_NAME, "export", total_records)
            record_success(SERVICE_NAME, "export", total_records)
            
            duration_ms = int((time.time() - start_time) * 1000)
            
            logger.info(
                f"Export completed successfully: {total_records} records in {duration_ms}ms",
                extra={
                    "extra_fields": {
                        "total_records": total_records,
                        "duration_ms": duration_ms,
                        "output_file": filepath,
                        "file_type": req.file.type,
                        "records_per_second": int(total_records / (duration_ms / 1000)) if duration_ms > 0 else 0,
                    }
                }
            )
            
            # Audit: Operation completed successfully
            await publish_audit_event(
                domain_id=DEFAULT_DOMAIN_ID,
                entity_type="OPERATION",
                entity_id=f"{req.db.table_name}->{req.file.output_path}",
                event_type="OPERATION_COMPLETED",
                outcome="SUCCESS",
                details=f"Completed DB-to-file export: {total_records} records in {duration_ms:.2f}ms",
                payload={
                    "operation_type": "db-to-file",
                    "source": req.db.table_name,
                    "destination": filepath,
                    "records_count": total_records,
                    "duration_ms": duration_ms,
                    "correlation_id": correlation_id,
                },
                metadata={
                    "correlation_id": correlation_id,
                    "source": req.db.table_name,
                    "destination": filepath,
                },
            )
            
            return ExportResponse(
                status="OK",
                records=total_records,
                file=filepath,
                duration_ms=duration_ms,
            )
        
        except HTTPException:
            raise
        except Exception as e:
            duration_ms = (time.time() - start_time) * 1000
            
            # Audit: Operation failed
            await publish_audit_event(
                domain_id=DEFAULT_DOMAIN_ID,
                entity_type="OPERATION",
                entity_id=f"{req.db.table_name}->{req.file.output_path}",
                event_type="OPERATION_FAILED",
                outcome="FAILURE",
                details=f"DB-to-file export failed: {type(e).__name__}: {str(e)}",
                payload={
                    "operation_type": "db-to-file",
                    "source": req.db.table_name,
                    "destination": req.file.output_path,
                    "error_type": type(e).__name__,
                    "error_message": str(e),
                    "records_processed": 0,
                    "duration_ms": duration_ms,
                    "correlation_id": correlation_id,
                },
                metadata={
                    "correlation_id": correlation_id,
                    "source": req.db.table_name,
                    "destination": req.file.output_path,
                },
            )
            
            log_error(logger, e, "export",
                     source_table=req.db.table_name,
                     output_path=req.file.output_path)
            record_error(SERVICE_NAME, "export", type(e).__name__)
            raise HTTPException(status_code=500, detail=f"Export failed: {str(e)}")


