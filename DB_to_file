class ColumnMapping(BaseModel):
    """
    Column mapping with value formatting for file export.
    
    Maps database column to file field with optional formatting for:
    - Date/datetime values (custom format strings)
    - Decimal values (precision control)
    - Fixed-width files (width, alignment, padding)
    
    Examples:
    ---------
    Date formatting:
        {
            "source": "created_date",
            "target": "created",
            "type": "date",
            "format": "%Y-%m-%d"
        }
    
    Decimal formatting:
        {
            "source": "amount",
            "target": "total",
            "type": "decimal",
            "format": "%.2f"
        }
    
    Fixed-width with alignment:
        {
            "source": "id",
            "target": "user_id",
            "type": "int",
            "width": 10,
            "align": "right",
            "pad_char": "0"
        }
    """
    source: str = Field(..., description="Source column name")
    target: str = Field(..., description="Target field name")
    type: str = Field(default="string", description="Data type: string, int, float, decimal, date, datetime")
    format: Optional[str] = Field(default=None, description="Format string for dates/decimals")
    width: Optional[int] = Field(default=None, description="Column width for fixed-width files")
    align: Optional[str] = Field(default="left", description="Alignment: left, right, center")
    pad_char: Optional[str] = Field(default=" ", description="Padding character")


class FilterCondition(BaseModel):
    column: str
    op: str = Field(..., description="Operator: eq, ne, lt, lte, gt, gte, like, ilike, in, between, is_null, is_not_null")
    value: Any = Field(default=None, description="Filter value")


class FileConfig(BaseModel):
    """
    File output configuration for export.
    
    Supports two file types:
    1. Delimited: CSV, TSV, or custom delimiter
    2. Fixed-Width: Positional data with alignment
    
    Features:
    ---------
    - Automatic filename generation with timestamp
    - Gzip compression (.gz)
    - Custom encoding (UTF-8, Latin-1, etc.)
    - Header row option
    - Null value representation
    
    Examples:
    ---------
    CSV file:
        {
            "type": "delimited",
            "output_path": "/data/exports",
            "filename_prefix": "users",
            "delimiter": ",",
            "header": true,
            "compress": false
        }
        Output: /data/exports/users_20251011_221303.csv
    
    TSV file with compression:
        {
            "type": "delimited",
            "output_path": "/data/exports",
            "delimiter": "\t",
            "compress": true
        }
        Output: /data/exports/export_20251011_221303.tsv.gz
    
    Fixed-width file:
        {
            "type": "fixed",
            "output_path": "/data/exports",
            "strict_width": true,
            "header": true
        }
        Output: /data/exports/export_20251011_221303.txt
    """
    type: str = Field(..., description="File type: 'delimited' or 'fixed'")
    output_path: str = Field(..., description="Output directory path")
    filename_prefix: str = Field(default="export", description="Output filename prefix")
    header: bool = Field(default=True, description="Include header row")
    encoding: str = Field(default="utf-8", description="File encoding")
    newline: str = Field(default="\n", description="Line terminator")
    compress: bool = Field(default=False, description="Gzip compression")
    null_literal: str = Field(default="", description="Null value representation")
    delimiter: str = Field(default=",", description="Delimiter for delimited files (supports multi-char like '||')")
    quotechar: str = Field(default='"', description="Quote character")
    escapechar: Optional[str] = Field(default=None, description="Escape character")
    strict_width: bool = Field(default=False, description="Enforce strict width for fixed files")
    sheet_name: str = Field(default="Sheet1", description="Sheet name for Excel files")
    include_correlation_id: bool = Field(default=False, description="Flag to Append CorrealtionId to Filename")


