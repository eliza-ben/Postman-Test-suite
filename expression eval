class QueryBuilderParser:
    """
    Parser for react-querybuilder JSON output.
    
    Converts react-querybuilder rules to executable expressions that can be
    evaluated against records. Supports all standard operators from react-querybuilder.
    """
    
    # Operator mapping from react-querybuilder to Python/expression evaluator
    OPERATOR_MAP = {
        # Equality
        '=': '==',
        '==': '==',
        '!=': '!=',
        '<>': '!=',
        
        # Comparison
        '<': '<',
        '>': '>',
        '<=': '<=',
        '>=': '>=',
        
        # String operators
        'contains': 'contains',
        'doesNotContain': 'not_contains',
        'beginsWith': 'starts_with',
        'doesNotBeginWith': 'not_starts_with',
        'endsWith': 'ends_with',
        'doesNotEndWith': 'not_ends_with',
        
        # Null checks
        'null': 'is_null',
        'notNull': 'is_not_null',
        
        # Collection operators
        'in': 'in',
        'notIn': 'not_in',
        'between': 'between',
        'notBetween': 'not_between',
    }
    
    def __init__(self):
        """Initialize the parser."""
        pass
    
    def evaluate_rule(self, rule: QueryBuilderRule, record: Dict[str, Any]) -> bool:
        """
        Evaluate a single rule against a record.
        
        Args:
            rule: The rule to evaluate
            record: The record to evaluate against
            
        Returns:
            True if the rule matches, False otherwise
        """
        field_value = record.get(rule.field)
        compare_value = rule.value
        
        # If valueSource is 'field', get value from another field
        if rule.valueSource == 'field' and isinstance(compare_value, str):
            compare_value = record.get(compare_value)
        
        operator = rule.operator
        
        try:
            # Equality operators
            if operator in ('=', '=='):
                return field_value == compare_value
            elif operator in ('!=', '<>'):
                return field_value != compare_value
            
            # Comparison operators
            elif operator == '<':
                return field_value is not None and compare_value is not None and field_value < compare_value
            elif operator == '>':
                return field_value is not None and compare_value is not None and field_value > compare_value
            elif operator == '<=':
                return field_value is not None and compare_value is not None and field_value <= compare_value
            elif operator == '>=':
                return field_value is not None and compare_value is not None and field_value >= compare_value
            
            # String operators
            elif operator == 'contains':
                return field_value is not None and compare_value is not None and str(compare_value) in str(field_value)
            elif operator == 'doesNotContain':
                return field_value is None or compare_value is None or str(compare_value) not in str(field_value)
            elif operator == 'beginsWith':
                return field_value is not None and compare_value is not None and str(field_value).startswith(str(compare_value))
            elif operator == 'doesNotBeginWith':
                return field_value is None or compare_value is None or not str(field_value).startswith(str(compare_value))
            elif operator == 'endsWith':
                return field_value is not None and compare_value is not None and str(field_value).endswith(str(compare_value))
            elif operator == 'doesNotEndWith':
                return field_value is None or compare_value is None or not str(field_value).endswith(str(compare_value))
            
            # Null checks
            elif operator == 'null':
                return field_value is None
            elif operator == 'notNull':
                return field_value is not None
            
            # Collection operators
            elif operator == 'in':
                if isinstance(compare_value, list):
                    return field_value in compare_value
                elif isinstance(compare_value, str):
                    # Handle comma-separated values
                    values = [v.strip() for v in compare_value.split(',')]
                    return str(field_value) in values
                return False
            elif operator == 'notIn':
                if isinstance(compare_value, list):
                    return field_value not in compare_value
                elif isinstance(compare_value, str):
                    values = [v.strip() for v in compare_value.split(',')]
                    return str(field_value) not in values
                return True
            elif operator == 'between':
                if isinstance(compare_value, list) and len(compare_value) >= 2:
                    return field_value is not None and compare_value[0] <= field_value <= compare_value[1]
                return False
            elif operator == 'notBetween':
                if isinstance(compare_value, list) and len(compare_value) >= 2:
                    return field_value is None or not (compare_value[0] <= field_value <= compare_value[1])
                return True
            
            else:
                logger.warning(f"Unknown operator: {operator}")
                return False
                
        except Exception as e:
            logger.error(f"Error evaluating rule {rule.field} {operator} {compare_value}: {e}")
            return False
    
    def evaluate_group(self, group: QueryBuilderRuleGroup, record: Dict[str, Any]) -> bool:
        """
        Evaluate a rule group against a record.
        
        Args:
            group: The rule group to evaluate
            record: The record to evaluate against
            
        Returns:
            True if the group matches, False otherwise
        """
        if not group.rules:
            return True  # Empty group matches everything
        
        results = []
        for rule in group.rules:
            if isinstance(rule, QueryBuilderRuleGroup):
                results.append(self.evaluate_group(rule, record))
            elif isinstance(rule, QueryBuilderRule):
                results.append(self.evaluate_rule(rule, record))
            elif isinstance(rule, dict):
                # Handle dict input (not yet parsed as model)
                if 'combinator' in rule:
                    # It's a nested group
                    nested_group = QueryBuilderRuleGroup(**rule)
                    results.append(self.evaluate_group(nested_group, record))
                else:
                    # It's a rule
                    parsed_rule = QueryBuilderRule(**rule)
                    results.append(self.evaluate_rule(parsed_rule, record))
        
        # Apply combinator
        if group.combinator.lower() == 'and':
            result = all(results)
        elif group.combinator.lower() == 'or':
            result = any(results)
        else:
            logger.warning(f"Unknown combinator: {group.combinator}, defaulting to 'and'")
            result = all(results)
        
        # Apply negation if specified
        if group.not_:
            result = not result
        
        return result
    
    def evaluate_record(
        self, 
        record: Dict[str, Any], 
        config: QueryBuilderConfig
    ) -> Dict[str, Any]:
        """
        Evaluate a query builder config against a record.
        
        Args:
            record: The source record
            config: The query builder configuration
            
        Returns:
            Record with the target column set based on query result
        """
        try:
            matches = self.evaluate_group(config.query, record)
            result = dict(record)
            result[config.target_column] = config.result_if_true if matches else config.result_if_false
            return result
        except Exception as e:
            logger.error(f"Error evaluating query builder config: {e}")
            result = dict(record)
            result[config.target_column] = config.default
            return result
    
    def evaluate_batch(
        self, 
        records: List[Dict[str, Any]], 
        configs: List[QueryBuilderConfig]
    ) -> List[Dict[str, Any]]:
        """
        Evaluate multiple query builder configs against a batch of records.
        
        Args:
            records: List of source records
            configs: List of query builder configurations
            
        Returns:
            List of records with target columns set
        """
        results = []
        for record in records:
            result = dict(record)
            for config in configs:
                evaluated = self.evaluate_record(result, config)
                result.update(evaluated)
            results.append(result)
        return results
    
    def convert_to_expression(self, group: QueryBuilderRuleGroup) -> str:
        """
        Convert a query builder rule group to an expression string.
        
        This generates an expression using the ${column} syntax that can be
        evaluated by the ExpressionEvaluator.
        
        Args:
            group: The rule group to convert
            
        Returns:
            Expression string
        """
        if not group.rules:
            return "True"
        
        expressions = []
        for rule in group.rules:
            if isinstance(rule, QueryBuilderRuleGroup):
                expr = f"({self.convert_to_expression(rule)})"
                expressions.append(expr)
            elif isinstance(rule, QueryBuilderRule):
                expr = self._rule_to_expression(rule)
                expressions.append(expr)
            elif isinstance(rule, dict):
                if 'combinator' in rule:
                    nested_group = QueryBuilderRuleGroup(**rule)
                    expr = f"({self.convert_to_expression(nested_group)})"
                    expressions.append(expr)
                else:
                    parsed_rule = QueryBuilderRule(**rule)
                    expr = self._rule_to_expression(parsed_rule)
                    expressions.append(expr)
        
        # Join with combinator
        joiner = ' and ' if group.combinator.lower() == 'and' else ' or '
        result = joiner.join(expressions)
        
        # Apply negation
        if group.not_:
            result = f"not ({result})"
        
        return result
    
    def _rule_to_expression(self, rule: QueryBuilderRule) -> str:
        """Convert a single rule to an expression string."""
        field_ref = f"${{{rule.field}}}"
        value = rule.value
        
        # Quote string values
        if isinstance(value, str):
            value_repr = f"'{value}'"
        elif value is None:
            value_repr = "None"
        elif isinstance(value, bool):
            value_repr = str(value)
        elif isinstance(value, list):
            value_repr = str(value)
        else:
            value_repr = str(value)
        
        operator = rule.operator
        
        # Map operators to expressions
        if operator in ('=', '=='):
            return f"{field_ref} == {value_repr}"
        elif operator in ('!=', '<>'):
            return f"{field_ref} != {value_repr}"
        elif operator in ('<', '>', '<=', '>='):
            return f"{field_ref} {operator} {value_repr}"
        elif operator == 'contains':
            return f"contains({field_ref}, {value_repr})"
        elif operator == 'doesNotContain':
            return f"not contains({field_ref}, {value_repr})"
        elif operator == 'beginsWith':
            return f"starts_with({field_ref}, {value_repr})"
        elif operator == 'doesNotBeginWith':
            return f"not starts_with({field_ref}, {value_repr})"
        elif operator == 'endsWith':
            return f"ends_with({field_ref}, {value_repr})"
        elif operator == 'doesNotEndWith':
            return f"not ends_with({field_ref}, {value_repr})"
        elif operator == 'null':
            return f"isnull({field_ref})"
        elif operator == 'notNull':
            return f"isnotnull({field_ref})"
        elif operator == 'in':
            return f"{field_ref} in {value_repr}"
        elif operator == 'notIn':
            return f"{field_ref} not in {value_repr}"
        elif operator == 'between':
            if isinstance(value, list) and len(value) >= 2:
                return f"({field_ref} >= {value[0]} and {field_ref} <= {value[1]})"
            return "False"
        elif operator == 'notBetween':
            if isinstance(value, list) and len(value) >= 2:
                return f"({field_ref} < {value[0]} or {field_ref} > {value[1]})"
            return "True"
        else:
            logger.warning(f"Unknown operator for conversion: {operator}")
            return "False"


class QueryBuilderProcessor:
    """
    Processor for react-querybuilder integration in ETL pipelines.
    
    Provides methods to evaluate react-querybuilder JSON output against records
    and create new columns based on query results.
    """
    
    def __init__(self):
        """Initialize the processor."""
        self.parser = QueryBuilderParser()
    
    async def process(
        self, 
        records: List[Dict[str, Any]], 
        configs: List[QueryBuilderConfig]
    ) -> List[Dict[str, Any]]:
        """
        Process records through query builder evaluation.
        
        Args:
            records: List of records to process
            configs: List of query builder configurations
            
        Returns:
            List of processed records with new columns
        """
        return self.parser.evaluate_batch(records, configs)


