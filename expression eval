class ExpressionProcessor:
    """
    Processor for expression evaluation in ETL pipelines.
    
    Provides a simple interface for integrating expression evaluation
    into the ETL pipeline alongside other processors like JOLT and aggregation.
    """
    
    def __init__(self):
        """Initialize the expression processor."""
        self.evaluator = ExpressionEvaluator()
    
    async def process(
        self, 
        records: List[Dict[str, Any]], 
        config: ExpressionConfig,
        source_records: Optional[List[Dict[str, Any]]] = None
    ) -> List[Dict[str, Any]]:
        """
        Process records through expression evaluation.
        
        Args:
            records: List of current records to process (after mapping/JOLT)
            config: Expression configuration
            source_records: Optional list of original source records for column references.
                           If provided, expressions can reference source columns via ${column}
                           while creating new target columns in the output.
            
        Returns:
            List of processed records with expression results
        """
        return await self.evaluator.evaluate_batch(records, config, source_records)


