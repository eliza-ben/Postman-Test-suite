def create_expression_config(
    expressions: List[Dict[str, Any]],
    preserve_unmapped: bool = False
) -> ExpressionConfig:
    """
    Create an ExpressionConfig from a list of expression dictionaries.
    
    Args:
        expressions: List of expression configs
        preserve_unmapped: Whether to preserve unmapped source columns
        
    Returns:
        ExpressionConfig instance
    """
    column_expressions = [
        ColumnExpression(
            target_column=e.get('target_column', e.get('target')),
            expression=e.get('expression'),
            default=e.get('default'),
            data_type=e.get('data_type', e.get('type'))
        )
        for e in expressions
    ]
    return ExpressionConfig(expressions=column_expressions, preserve_unmapped=preserve_unmapped)


