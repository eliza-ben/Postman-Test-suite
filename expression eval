    def _fn_concat(self, *args) -> Optional[str]:
        """Concatenate strings, handling nulls."""
        parts = []
        for arg in args:
            if arg is not None:
                parts.append(str(arg))
        return ''.join(parts) if parts else None
    
    def _fn_substring(self, s, start, length=None) -> Optional[str]:
        """Extract substring from string."""
        if s is None:
            return None
        s = str(s)
        start = int(start)
        if length is not None:
            return s[start:start + int(length)]
        return s[start:]
    
    def _fn_regex_match(self, s, pattern) -> bool:
        """Check if string matches regex pattern."""
        if s is None or pattern is None:
            return False
        return bool(re.match(pattern, str(s)))
    
    def _fn_regex_replace(self, s, pattern, replacement) -> Optional[str]:
        """Replace regex matches in string."""
        if s is None:
            return None
        return re.sub(pattern, replacement, str(s))
    
    def _fn_avg(self, *args) -> Optional[float]:
        """Calculate average of non-null values."""
        values = [float(x) for x in args if x is not None]
        return sum(values) / len(values) if values else None
    
    def _fn_int(self, x) -> Optional[int]:
        """Convert to integer safely."""
        if x is None:
            return None
        try:
            if isinstance(x, str):
                x = x.strip()
                if x.lower() in ('', 'null', 'none', 'nan'):
                    return None
            return int(float(x))
        except (ValueError, TypeError):
            return None
    
    def _fn_float(self, x) -> Optional[float]:
        """Convert to float safely."""
        if x is None:
            return None
        try:
            if isinstance(x, str):
                x = x.strip()
                if x.lower() in ('', 'null', 'none', 'nan'):
                    return None
            return float(x)
        except (ValueError, TypeError):
            return None
    
    def _fn_bool(self, x) -> Optional[bool]:
        """Convert to boolean safely."""
        if x is None:
            return None
        if isinstance(x, bool):
            return x
        if isinstance(x, (int, float)):
            return bool(x)
        if isinstance(x, str):
            x = x.strip().lower()
            if x in ('true', 'yes', '1', 'y', 't', 'on'):
                return True
            if x in ('false', 'no', '0', 'n', 'f', 'off', ''):
                return False
        return None
    
    def _fn_decimal(self, x, precision=None) -> Optional[Decimal]:
        """Convert to Decimal safely."""
        if x is None:
            return None
        try:
            if isinstance(x, str):
                x = x.strip()
                if x.lower() in ('', 'null', 'none', 'nan'):
                    return None
            d = Decimal(str(x))
            if precision is not None:
                d = round(d, int(precision))
            return d
        except (InvalidOperation, ValueError, TypeError):
            return None
    
    def _fn_date(self, x) -> Optional[date]:
        """Convert to date safely."""
        if x is None:
            return None
        if isinstance(x, datetime):
            return x.date()
        if isinstance(x, date):
            return x
        try:
            return date_parser.parse(str(x)).date()
        except (ValueError, TypeError):
            return None
    
    def _fn_datetime(self, x) -> Optional[datetime]:
        """Convert to datetime safely."""
        if x is None:
            return None
        if isinstance(x, datetime):
            return x
        if isinstance(x, date):
            return datetime.combine(x, datetime.min.time())
        try:
            return date_parser.parse(str(x))
        except (ValueError, TypeError):
            return None
    
    def _fn_time(self, x) -> Optional[time]:
        """Convert to time object safely."""
        if x is None:
            return None
        if isinstance(x, time):
            return x
        if isinstance(x, datetime):
            return x.time()
        try:
            # Parse HH:MM:SS or HH:MM format
            str_val = str(x).strip()
            parts = str_val.split(':')
            if len(parts) >= 2:
                hour = int(parts[0])
                minute = int(parts[1])
                second = int(parts[2]) if len(parts) > 2 else 0
                return time(hour, minute, second)
            return None
        except (ValueError, TypeError):
            return None
    
    def _fn_time_parse(self, s, fmt=None) -> Optional[time]:
        """Parse string to time object."""
        if s is None:
            return None
        try:
            str_val = str(s).strip()
            if fmt:
                dt = datetime.strptime(str_val, fmt)
                return dt.time()
            # Default HH:MM:SS parsing
            return self._fn_time(str_val)
        except (ValueError, TypeError):
            return None
    
    def _fn_date_format(self, d, fmt='%Y-%m-%d') -> Optional[str]:
        """Format date/datetime as string."""
        if d is None:
            return None
        dt = self._fn_datetime(d)
        if dt is None:
            return None
        return dt.strftime(fmt)
    
    def _fn_date_parse(self, s, fmt=None) -> Optional[datetime]:
        """Parse string to datetime."""
        if s is None:
            return None
        try:
            if fmt:
                return datetime.strptime(str(s), fmt)
            return date_parser.parse(str(s))
        except (ValueError, TypeError):
            return None
    
    def _fn_date_add(self, d, value, unit='days') -> Optional[datetime]:
        """Add time to a date."""
        if d is None:
            return None
        dt = self._fn_datetime(d)
        if dt is None:
            return None
        value = int(value)
        unit = unit.lower()
        if unit in ('day', 'days', 'd'):
            return dt + timedelta(days=value)
        elif unit in ('hour', 'hours', 'h'):
            return dt + timedelta(hours=value)
        elif unit in ('minute', 'minutes', 'm'):
            return dt + timedelta(minutes=value)
        elif unit in ('second', 'seconds', 's'):
            return dt + timedelta(seconds=value)
        elif unit in ('week', 'weeks', 'w'):
            return dt + timedelta(weeks=value)
        elif unit in ('month', 'months'):
            return dt + relativedelta(months=value)
        elif unit in ('year', 'years', 'y'):
            return dt + relativedelta(years=value)
        return dt
    
    def _fn_date_diff(self, d1, d2, unit='days') -> Optional[int]:
        """Calculate difference between two dates."""
        if d1 is None or d2 is None:
            return None
        dt1 = self._fn_datetime(d1)
        dt2 = self._fn_datetime(d2)
        if dt1 is None or dt2 is None:
            return None
        delta = dt1 - dt2
        unit = unit.lower()
        if unit in ('day', 'days', 'd'):
            return delta.days
        elif unit in ('hour', 'hours', 'h'):
            return int(delta.total_seconds() / 3600)
        elif unit in ('minute', 'minutes', 'm'):
            return int(delta.total_seconds() / 60)
        elif unit in ('second', 'seconds', 's'):
            return int(delta.total_seconds())
        return delta.days
    
    def _fn_date_part(self, d, part) -> Optional[int]:
        """Extract part from date/datetime."""
        if d is None:
            return None
        dt = self._fn_datetime(d)
        if dt is None:
            return None
        if part == 'year':
            return dt.year
        elif part == 'month':
            return dt.month
        elif part == 'day':
            return dt.day
        elif part == 'hour':
            return dt.hour
        elif part == 'minute':
            return dt.minute
        elif part == 'second':
            return dt.second
        elif part == 'millisecond':
            return dt.microsecond // 1000
        elif part == 'weekday':
            return dt.weekday()
        elif part == 'dayofyear':
            return dt.timetuple().tm_yday
        elif part == 'week':
            return dt.isocalendar()[1]
        elif part == 'quarter':
            return (dt.month - 1) // 3 + 1
        return None
    
    def _fn_is_leap_year(self, d) -> Optional[bool]:
        """Check if year is a leap year."""
        if d is None:
            return None
        dt = self._fn_datetime(d)
        if dt is None:
            return None
        year = dt.year
        return year % 4 == 0 and (year % 100 != 0 or year % 400 == 0)
    
    def _fn_days_in_month(self, d) -> Optional[int]:
        """Get number of days in month."""
        if d is None:
            return None
        dt = self._fn_datetime(d)
        if dt is None:
            return None
        import calendar
        return calendar.monthrange(dt.year, dt.month)[1]
    
    def _fn_start_of(self, d, unit) -> Optional[datetime]:
        """Get start of day/month/year."""
        if d is None:
            return None
        dt = self._fn_datetime(d)
        if dt is None:
            return None
        if unit == 'day':
            return datetime(dt.year, dt.month, dt.day, 0, 0, 0)
        elif unit == 'month':
            return datetime(dt.year, dt.month, 1, 0, 0, 0)
        elif unit == 'year':
            return datetime(dt.year, 1, 1, 0, 0, 0)
        return dt
    
    def _fn_end_of(self, d, unit) -> Optional[datetime]:
        """Get end of day/month/year."""
        if d is None:
            return None
        dt = self._fn_datetime(d)
        if dt is None:
            return None
        if unit == 'day':
            return datetime(dt.year, dt.month, dt.day, 23, 59, 59, 999999)
        elif unit == 'month':
            import calendar
            last_day = calendar.monthrange(dt.year, dt.month)[1]
            return datetime(dt.year, dt.month, last_day, 23, 59, 59, 999999)
        elif unit == 'year':
            return datetime(dt.year, 12, 31, 23, 59, 59, 999999)
        return dt
    
    def _fn_compare_dates(self, d1, d2) -> int:
        """Compare two dates. Returns -1, 0, or 1."""
        if d1 is None or d2 is None:
            return 0
        dt1 = self._fn_datetime(d1)
        dt2 = self._fn_datetime(d2)
        if dt1 is None or dt2 is None:
            return 0
        if dt1 < dt2:
            return -1
        elif dt1 > dt2:
            return 1
        return 0
    
    def _fn_is_same(self, d1, d2, unit) -> bool:
        """Check if two dates are the same day/month/year."""
        if d1 is None or d2 is None:
            return False
        dt1 = self._fn_datetime(d1)
        dt2 = self._fn_datetime(d2)
        if dt1 is None or dt2 is None:
            return False
        if unit == 'day':
            return dt1.date() == dt2.date()
        elif unit == 'month':
            return dt1.year == dt2.year and dt1.month == dt2.month
        elif unit == 'year':
            return dt1.year == dt2.year
        return False
    
    def _fn_is_weekend(self, d) -> bool:
        """Check if date is weekend (Saturday=5 or Sunday=6)."""
        if d is None:
            return False
        dt = self._fn_datetime(d)
        if dt is None:
            return False
        return dt.weekday() >= 5
    
    def _fn_to_timestamp(self, d) -> Optional[int]:
        """Convert date to Unix timestamp (seconds since epoch)."""
        if d is None:
            return None
        dt = self._fn_datetime(d)
        if dt is None:
            return None
        return int(dt.timestamp())
    
    def _fn_from_timestamp(self, ts) -> Optional[datetime]:
        """Convert Unix timestamp to datetime."""
        if ts is None:
            return None
        try:
            return datetime.fromtimestamp(float(ts))
        except (ValueError, TypeError, OSError):
            return None
    
    def _fn_format(self, template, *args):
        """Format string with arguments (sprintf-style)."""
        if template is None:
            return None
        try:
            if args:
                return str(template) % args
            return str(template)
        except (TypeError, ValueError):
            return str(template)
    
    def _fn_if(self, condition, then_value, else_value=None):
        """Conditional if-then-else."""
        if condition:
            return then_value
        return else_value
    
    def _fn_case(self, value, *args):
        """
        CASE expression: case(value, match1, result1, match2, result2, ..., default)
        If odd number of args after value, last is default.
        """
        default = None
        pairs = list(args)
        if len(pairs) % 2 == 1:
            default = pairs.pop()
        
        for i in range(0, len(pairs), 2):
            if value == pairs[i]:
                return pairs[i + 1]
        return default
    
    def _fn_coalesce(self, *args):
        """Return first non-null value."""
        for arg in args:
            if arg is not None:
                return arg
        return None
    
    def _fn_map(self, value, mapping_dict, default=None):
        """Map value using a dictionary."""
        if not isinstance(mapping_dict, dict):
            return default
        return mapping_dict.get(value, default)
    
    def _fn_flatten(self, lst):
        """Flatten nested lists."""
        if lst is None:
            return None
        result = []
        for item in lst:
            if isinstance(item, list):
                result.extend(self._fn_flatten(item))
            else:
                result.append(item)
        return result
    
    # =========================================================================
    # ADVANCED LOGIC OPERATOR IMPLEMENTATIONS
    # =========================================================================
    
    def _fn_between(self, x, low, high) -> bool:
        """Check if value is between low and high (inclusive)."""
        if x is None or low is None or high is None:
            return False
        try:
            return low <= x <= high
        except TypeError:
            # Try numeric comparison
            try:
                return float(low) <= float(x) <= float(high)
            except (ValueError, TypeError):
                return False
    
    def _fn_in_list(self, x, *values) -> bool:
        """Check if value is in list of values (SQL IN operator)."""
        if x is None:
            return False
        # Handle single list argument
        if len(values) == 1 and isinstance(values[0], (list, tuple)):
            values = values[0]
        return x in values
    
    def _fn_like(self, s, pattern) -> bool:
        """SQL LIKE pattern matching. Supports % (any chars) and _ (single char)."""
        if s is None or pattern is None:
            return False
        s = str(s)
        # Convert SQL LIKE pattern to regex
        regex_pattern = pattern.replace('%', '.*').replace('_', '.')
        # Escape other regex special chars but keep .* and .
        regex_pattern = '^' + regex_pattern + '$'
        try:
            return bool(re.match(regex_pattern, s))
        except re.error:
            return False
    
    def _fn_ilike(self, s, pattern) -> bool:
        """Case-insensitive LIKE pattern matching."""
        if s is None or pattern is None:
            return False
        s = str(s).lower()
        pattern = pattern.lower()
        return self._fn_like(s, pattern)
    
    def _fn_regex_extract(self, s, pattern, group=0) -> Optional[str]:
        """Extract first regex match from string."""
        if s is None or pattern is None:
            return None
        try:
            match = re.search(pattern, str(s))
            if match:
                if group == 0:
                    return match.group(0)
                elif group <= len(match.groups()):
                    return match.group(group)
            return None
        except re.error:
            return None
    
    def _fn_regex_extract_all(self, s, pattern) -> Optional[list]:
        """Extract all regex matches from string."""
        if s is None or pattern is None:
            return None
        try:
            return re.findall(pattern, str(s))
        except re.error:
            return None
    
    def _fn_switch(self, value, *cases):
        """
        Switch expression: switch(value, case1, result1, case2, result2, ..., default)
        Similar to case() but evaluates conditions.
        """
        default = None
        pairs = list(cases)
        if len(pairs) % 2 == 1:
            default = pairs.pop()
        
        for i in range(0, len(pairs), 2):
            if value == pairs[i]:
                return pairs[i + 1]
        return default
    
    def _fn_choose(self, index, *values):
        """
        Choose value by index: choose(2, 'a', 'b', 'c') returns 'b' (1-indexed).
        """
        if index is None:
            return None
        try:
            idx = int(index) - 1  # 1-indexed
            if 0 <= idx < len(values):
                return values[idx]
            return None
        except (ValueError, TypeError):
            return None
    
    def _fn_decode(self, expr, *pairs):
        """
        Oracle-style DECODE: decode(expr, search1, result1, search2, result2, ..., default)
        """
        default = None
        args = list(pairs)
        if len(args) % 2 == 1:
            default = args.pop()
        
        for i in range(0, len(args), 2):
            if expr == args[i]:
                return args[i + 1]
        return default
    
    def _fn_is_number(self, x) -> bool:
        """Check if value is a number or can be converted to number."""
        if x is None:
            return False
        if isinstance(x, (int, float, Decimal)):
            return True
        if isinstance(x, str):
            try:
                float(x)
                return True
            except ValueError:
                return False
        return False
    
    def _fn_is_integer(self, x) -> bool:
        """Check if value is an integer or can be converted to integer."""
        if x is None:
            return False
        if isinstance(x, int) and not isinstance(x, bool):
            return True
        if isinstance(x, float):
            return x.is_integer()
        if isinstance(x, str):
            try:
                val = float(x)
                return val.is_integer()
            except ValueError:
                return False
        return False
    
    def _fn_is_decimal(self, x) -> bool:
        """Check if value is a decimal number (has fractional part)."""
        if x is None:
            return False
        if isinstance(x, Decimal):
            return True
        if isinstance(x, float):
            return not x.is_integer()
        if isinstance(x, str):
            try:
                val = float(x)
                return not val.is_integer()
            except ValueError:
                return False
        return False
    
    def _fn_is_date(self, x) -> bool:
        """Check if value is a date or can be parsed as date."""
        if x is None:
            return False
        if isinstance(x, (date, datetime)):
            return True
        if isinstance(x, str):
            try:
                date_parser.parse(x)
                return True
            except (ValueError, TypeError):
                return False
        return False
    
    def _fn_typeof(self, x) -> str:
        """Return the type name of a value."""
        if x is None:
            return 'null'
        if isinstance(x, bool):
            return 'boolean'
        if isinstance(x, int):
            return 'integer'
        if isinstance(x, float):
            return 'float'
        if isinstance(x, Decimal):
            return 'decimal'
        if isinstance(x, str):
            return 'string'
        if isinstance(x, datetime):
            return 'datetime'
        if isinstance(x, date):
            return 'date'
        if isinstance(x, (list, tuple)):
            return 'list'
        if isinstance(x, dict):
            return 'object'
        return type(x).__name__
    
    # =========================================================================
    # EXPRESSION PARSING AND EVALUATION
    # =========================================================================
    
    def _get_nested_value(self, record: Dict[str, Any], path: str) -> Any:
        """Get value from record using dot notation for nested fields."""
        parts = path.split('.')
        value = record
        for part in parts:
            if isinstance(value, dict):
                value = value.get(part)
            else:
                return None
        return value
    
    def _substitute_column_refs(self, expression: str, record: Dict[str, Any]) -> str:
        """Replace ${column_name} references with actual values."""
        def replace_ref(match):
            column_path = match.group(1)
            value = self._get_nested_value(record, column_path)
            if value is None:
                return 'None'
            elif isinstance(value, str):
                # Escape quotes in strings and wrap in quotes
                escaped = value.replace('\\', '\\\\').replace("'", "\\'")
                return f"'{escaped}'"
            elif isinstance(value, bool):
                return 'True' if value else 'False'
            elif isinstance(value, (int, float, Decimal)):
                return str(value)
            elif isinstance(value, (datetime, date)):
                return f"'{value.isoformat()}'"
            elif isinstance(value, (list, dict)):
                return repr(value)
            else:
                return repr(value)
        
        return self.COLUMN_REF_PATTERN.sub(replace_ref, expression)
    
    def _safe_eval(self, expression: str, record: Dict[str, Any]) -> Any:
        """
        Safely evaluate an expression with column references substituted.
        """
        # Substitute column references
        substituted = self._substitute_column_refs(expression, record)
        
        # Build safe evaluation context
        safe_context = {
            '__builtins__': {},  # Disable all builtins for security
            'True': True,
            'False': False,
            'None': None,
        }
        
        # Add all registered functions
        safe_context.update(self.functions)
        
        # Add operators as functions for complex expressions
        safe_context.update({
            'and_': lambda a, b: a and b,
            'or_': lambda a, b: a or b,
            'not_': lambda a: not a,
        })
        
        try:
            # Evaluate the expression
            result = eval(substituted, safe_context)
            return result
        except Exception as e:
            logger.warning(f"Expression evaluation failed: {expression} -> {substituted}. Error: {e}")
            return None
    
    def _convert_type(self, value: Any, data_type: Optional[str]) -> Any:
        """Convert value to specified data type."""
        if value is None or data_type is None:
            return value
        
        data_type = data_type.lower()
        
        if data_type in ('string', 'str', 'varchar', 'text'):
            return str(value) if value is not None else None
        elif data_type in ('int', 'integer', 'bigint'):
            return self._fn_int(value)
        elif data_type in ('float', 'double', 'real'):
            return self._fn_float(value)
        elif data_type in ('decimal', 'numeric'):
            return self._fn_decimal(value)
        elif data_type in ('bool', 'boolean'):
            return self._fn_bool(value)
        elif data_type in ('date',):
            return self._fn_date(value)
        elif data_type in ('datetime', 'timestamp'):
            return self._fn_datetime(value)
        
        return value
    
    def evaluate_expression(
        self, 
        expression: str, 
        record: Dict[str, Any],
        default: Any = None,
        data_type: Optional[str] = None
    ) -> Any:
        """
        Evaluate a single expression against a record.
        
        Args:
            expression: Expression string with ${column} references
            record: Source record dictionary
            default: Default value if expression evaluates to None or fails
            data_type: Optional target data type for conversion
            
        Returns:
            Evaluated value
        """
        try:
            result = self._safe_eval(expression, record)
            
            # Apply default if result is None
            if result is None and default is not None:
                result = default
            
            # Apply type conversion
            if data_type:
                result = self._convert_type(result, data_type)
            
            return result
        except Exception as e:
            logger.error(f"Expression evaluation error: {expression}. Error: {e}")
            return default
    
    def evaluate_record(
        self, 
        record: Dict[str, Any], 
        config: ExpressionConfig,
        source_record: Optional[Dict[str, Any]] = None
    ) -> Dict[str, Any]:
        """
        Evaluate all expressions for a single record.
        
        Args:
            record: Current record dictionary (after mapping/JOLT)
            config: Expression configuration
            source_record: Original source record for column references (optional)
                          If provided, expressions reference source columns.
                          If not provided, expressions reference current record columns.
            
        Returns:
            New record with evaluated expressions
        """
        result = {}
        
        # Optionally preserve unmapped columns from current record
        if config.preserve_unmapped:
            result = dict(record)
        
        # Use source_record for expression evaluation if provided, otherwise use current record
        # This allows expressions to reference original source columns while creating target columns
        eval_record = source_record if source_record is not None else record
        
        # Get available columns for expr-eval syntax conversion
        available_columns = list(eval_record.keys()) if eval_record else None
        
        # Evaluate each expression using source data, store in target columns
        for expr_config in config.expressions:
            try:
                # Normalize expression to template syntax (supports expr-eval 2.0.2)
                syntax = expr_config.syntax if expr_config.syntax else 'auto'
                normalized_expr = self.normalize_expression(
                    expr_config.expression, 
                    syntax, 
                    available_columns
                )
                
                value = self.evaluate_expression(
                    normalized_expr,
                    eval_record,  # Use source record for column references
                    expr_config.default,
                    expr_config.data_type
                )
                result[expr_config.target_column] = value
            except Exception as e:
                logger.error(f"Failed to evaluate expression for column {expr_config.target_column}: {e}")
                result[expr_config.target_column] = expr_config.default
        
        return result
    
    async def evaluate_batch(
        self, 
        records: List[Dict[str, Any]], 
        config: ExpressionConfig,
        source_records: Optional[List[Dict[str, Any]]] = None,
        use_parallel: bool = True,
        chunk_size: int = 5000
    ) -> List[Dict[str, Any]]:
        """
        Evaluate expressions for a batch of records with performance optimizations.
        
        Args:
            records: List of current records (after mapping/JOLT)
            config: Expression configuration
            source_records: Optional list of original source records for column references.
                           If provided, expressions reference source columns while creating
                           target columns in the output. Must have same length as records.
            use_parallel: Use parallel processing for large batches (default: True)
            chunk_size: Chunk size for parallel processing (default: 5000)
            
        Returns:
            List of records with evaluated expressions
        """
        if not records:
            return []
        
        record_count = len(records)
        expression_count = len(config.expressions)
        
        # Validate source_records length if provided
        if source_records is not None and len(source_records) != record_count:
            logger.warning(f"source_records length ({len(source_records)}) doesn't match records length ({record_count}). Using current records for evaluation.")
            source_records = None
        
        # For small batches, use simple sequential processing
        if record_count < 1000 or not use_parallel:
            results = []
            for i, record in enumerate(records):
                source_rec = source_records[i] if source_records else None
                evaluated = self.evaluate_record(record, config, source_rec)
                results.append(evaluated)
            logger.info(f"Evaluated expressions for {len(results)} records ({expression_count} expressions) - sequential")
            return results
        
        # For large batches, use parallel processing with chunking
        import concurrent.futures
        import asyncio
        
        def process_chunk(chunk_data: tuple) -> List[Dict[str, Any]]:
            """Process a chunk of records."""
            chunk_records, chunk_sources = chunk_data
            chunk_results = []
            for i, record in enumerate(chunk_records):
                source_rec = chunk_sources[i] if chunk_sources else None
                evaluated = self.evaluate_record(record, config, source_rec)
                chunk_results.append(evaluated)
            return chunk_results
        
        # Split records into chunks (with corresponding source records if provided)
        chunks = []
        for i in range(0, record_count, chunk_size):
            chunk_records = records[i:i + chunk_size]
            chunk_sources = source_records[i:i + chunk_size] if source_records else None
            chunks.append((chunk_records, chunk_sources))
        
        # Process chunks in parallel using ThreadPoolExecutor
        loop = asyncio.get_event_loop()
        results = []
        
        with concurrent.futures.ThreadPoolExecutor(max_workers=min(len(chunks), 8)) as executor:
            futures = [loop.run_in_executor(executor, process_chunk, chunk_data) for chunk_data in chunks]
            chunk_results = await asyncio.gather(*futures)
            
            for chunk_result in chunk_results:
                results.extend(chunk_result)
        
        logger.info(f"Evaluated expressions for {len(results)} records ({expression_count} expressions) - parallel ({len(chunks)} chunks)")
        return results


