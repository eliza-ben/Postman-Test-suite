class ExpressionEvaluator:
    """
    Safe expression evaluator for ETL column transformations.
    
    Provides a sandboxed environment for evaluating expressions that reference
    source columns and apply various operations. All functions are whitelisted
    to prevent arbitrary code execution.
    """
    
    # Regex pattern to match column references: ${column_name} or ${parent.child}
    COLUMN_REF_PATTERN = re.compile(r'\$\{([a-zA-Z_][a-zA-Z0-9_\.]*)\}')
    
    # Regex pattern to match expr-eval bare variable names (identifiers not inside quotes or functions)
    # Matches word characters that are valid identifiers but excludes Python keywords and our functions
    EXPR_EVAL_VAR_PATTERN = re.compile(r'(?<![\w$])([a-zA-Z_][a-zA-Z0-9_]*)(?![\w(])')
    
    # Python keywords and built-in constants to exclude from variable detection
    RESERVED_WORDS = {
        'and', 'or', 'not', 'in', 'is', 'True', 'False', 'None',
        'if', 'else', 'elif', 'for', 'while', 'break', 'continue', 'return',
        'def', 'class', 'import', 'from', 'as', 'try', 'except', 'finally',
        'with', 'lambda', 'yield', 'global', 'nonlocal', 'assert', 'pass',
        'del', 'raise', 'E', 'PI', 'true', 'false', 'null'
    }
    
    # Safe operators for arithmetic evaluation
    OPERATORS = {
        '+': operator.add,
        '-': operator.sub,
        '*': operator.mul,
        '/': operator.truediv,
        '//': operator.floordiv,
        '%': operator.mod,
        '**': operator.pow,
        '==': operator.eq,
        '!=': operator.ne,
        '<': operator.lt,
        '>': operator.gt,
        '<=': operator.le,
        '>=': operator.ge,
    }
    
    def __init__(self):
        """Initialize the expression evaluator with built-in functions and caching."""
        self.functions = self._build_function_registry()
        # Expression template cache for performance optimization
        self._expression_cache: Dict[str, str] = {}
        self._cache_hits = 0
        self._cache_misses = 0
    
    # expr-eval 2.0.2 operator mappings
    EXPR_EVAL_OPERATOR_MAP = {
        '&&': ' and ',
        '||': ' or ',
        '^': '**',  # exponentiation
    }
    
    # expr-eval 2.0.2 function mappings to our functions
    EXPR_EVAL_FUNCTION_MAP = {
        # Math functions (expr-eval → our function)
        'sin': 'sin',
        'cos': 'cos',
        'tan': 'tan',
        'asin': 'asin',
        'acos': 'acos',
        'atan': 'atan',
        'sinh': 'sinh',
        'cosh': 'cosh',
        'tanh': 'tanh',
        'sqrt': 'sqrt',
        'cbrt': 'cbrt',
        'log': 'log',
        'log2': 'log2',
        'log10': 'log10',
        'ln': 'log',
        'exp': 'exp',
        'abs': 'abs',
        'ceil': 'ceil',
        'floor': 'floor',
        'round': 'round',
        'trunc': 'trunc',
        'sign': 'sign',
        'min': 'min',
        'max': 'max',
        'pow': 'power',
        'atan2': 'atan2',
        'random': 'random',
        'fac': 'factorial',
        # String functions
        'length': 'length',
        'concat': 'concat',
        # Conditional
        'if': 'if',
    }
    
    def convert_expr_eval_to_template(
        self, 
        expression: str, 
        available_columns: Optional[List[str]] = None
    ) -> str:
        """
        Convert expr-eval 2.0.2 syntax to template syntax.
        
        Handles full expr-eval syntax including:
        - Bare variable names: `quantity * price` → `${quantity} * ${price}`
        - Ternary operator: `a > b ? x : y` → `if(a > b, x, y)`
        - Logical operators: `&&` → `and`, `||` → `or`, `!x` → `not x`
        - Exponentiation: `^` → `**`
        - All comparison operators: ==, !=, <, >, <=, >=
        - Math functions: sin, cos, sqrt, abs, etc.
        - String operations
        
        Args:
            expression: Expression in expr-eval syntax
            available_columns: Optional list of column names to use for variable detection.
                             
        Returns:
            Expression in template syntax with ${column} references
            
        Examples:
            "quantity * price"           → "${quantity} * ${price}"
            "age > 18 ? 'adult' : 'minor'" → "if(${age} > 18, 'adult', 'minor')"
            "a && b || !c"               → "${a} and ${b} or not ${c}"
            "2 ^ 3"                      → "2**3"
            "firstName || ' ' || lastName" → "concat(${firstName}, ' ', ${lastName})"
        """
        if not expression:
            return expression
        
        # If expression already uses template syntax, return as-is
        if '${' in expression:
            return expression
        
        # Step 1: Convert ternary operators (must be done first, recursively)
        expression = self._convert_ternary_to_if(expression)
        
        # Step 2: Convert logical operators
        expression = self._convert_logical_operators(expression)
        
        # Step 3: Convert exponentiation ^ to **
        expression = self._convert_exponentiation(expression)
        
        # Step 4: Convert string concatenation || to concat()
        expression = self._convert_string_concat(expression)
        
        # Step 5: Convert bare variable names to ${column} syntax
        expression = self._convert_variables_to_template(expression, available_columns)
        
        return expression
    
    def _convert_ternary_to_if(self, expression: str) -> str:
        """
        Convert ternary operator `condition ? trueVal : falseVal` to `if(condition, trueVal, falseVal)`.
        Handles nested ternaries.
        """
        result = []
        i = 0
        in_string = False
        string_char = None
        paren_depth = 0
        
        while i < len(expression):
            char = expression[i]
            
            # Track string literals
            if char in ('"', "'") and (i == 0 or expression[i-1] != '\\'):
                if not in_string:
                    in_string = True
                    string_char = char
                elif char == string_char:
                    in_string = False
                    string_char = None
                result.append(char)
                i += 1
                continue
            
            if in_string:
                result.append(char)
                i += 1
                continue
            
            # Track parentheses
            if char == '(':
                paren_depth += 1
            elif char == ')':
                paren_depth -= 1
            
            # Found ternary operator ?
            if char == '?' and paren_depth == 0:
                # Find the matching : for this ?
                colon_pos = self._find_matching_colon(expression, i + 1)
                if colon_pos != -1:
                    # Extract condition (everything before ?)
                    condition = ''.join(result).strip()
                    result = []
                    
                    # Extract true value (between ? and :)
                    true_val = expression[i + 1:colon_pos].strip()
                    
                    # Extract false value (after :)
                    # Find end - either end of string or next operator at same level
                    false_end = len(expression)
                    false_val = expression[colon_pos + 1:false_end].strip()
                    
                    # Recursively convert nested ternaries
                    true_val = self._convert_ternary_to_if(true_val)
                    false_val = self._convert_ternary_to_if(false_val)
                    condition = self._convert_ternary_to_if(condition)
                    
                    result.append(f'if({condition}, {true_val}, {false_val})')
                    i = false_end
                    continue
            
            result.append(char)
            i += 1
        
        return ''.join(result)
    
    def _find_matching_colon(self, expression: str, start: int) -> int:
        """Find the matching : for a ternary operator, respecting nesting."""
        depth = 0
        in_string = False
        string_char = None
        
        for i in range(start, len(expression)):
            char = expression[i]
            
            # Track strings
            if char in ('"', "'") and (i == 0 or expression[i-1] != '\\'):
                if not in_string:
                    in_string = True
                    string_char = char
                elif char == string_char:
                    in_string = False
            
            if in_string:
                continue
            
            if char == '(':
                depth += 1
            elif char == ')':
                depth -= 1
            elif char == '?':
                depth += 1  # Nested ternary
            elif char == ':' and depth == 0:
                return i
            elif char == ':' and depth > 0:
                depth -= 1  # End of nested ternary
        
        return -1
    
    def _convert_logical_operators(self, expression: str) -> str:
        """Convert && to 'and', || to 'or', !x to 'not x'."""
        result = []
        i = 0
        in_string = False
        string_char = None
        
        while i < len(expression):
            char = expression[i]
            
            # Track string literals
            if char in ('"', "'") and (i == 0 or expression[i-1] != '\\'):
                if not in_string:
                    in_string = True
                    string_char = char
                elif char == string_char:
                    in_string = False
                    string_char = None
                result.append(char)
                i += 1
                continue
            
            if in_string:
                result.append(char)
                i += 1
                continue
            
            # Check for &&
            if char == '&' and i + 1 < len(expression) and expression[i + 1] == '&':
                result.append(' and ')
                i += 2
                continue
            
            # Check for || (logical or, not string concat - handle separately)
            if char == '|' and i + 1 < len(expression) and expression[i + 1] == '|':
                # This might be string concat or logical OR - we'll handle in separate pass
                result.append('||')
                i += 2
                continue
            
            # Check for ! (not operator) - but not !=
            if char == '!' and i + 1 < len(expression) and expression[i + 1] != '=':
                result.append('not ')
                i += 1
                continue
            
            result.append(char)
            i += 1
        
        return ''.join(result)
    
    def _convert_exponentiation(self, expression: str) -> str:
        """Convert ^ to ** for exponentiation."""
        result = []
        i = 0
        in_string = False
        string_char = None
        
        while i < len(expression):
            char = expression[i]
            
            if char in ('"', "'") and (i == 0 or expression[i-1] != '\\'):
                if not in_string:
                    in_string = True
                    string_char = char
                elif char == string_char:
                    in_string = False
                    string_char = None
                result.append(char)
                i += 1
                continue
            
            if in_string:
                result.append(char)
                i += 1
                continue
            
            if char == '^':
                result.append('**')
                i += 1
                continue
            
            result.append(char)
            i += 1
        
        return ''.join(result)
    
    def _convert_string_concat(self, expression: str) -> str:
        """
        Convert || used for string concatenation to concat().
        This is tricky because || could also be logical OR.
        We convert || to concat() when operands appear to be strings.
        """
        # For now, convert remaining || to 'or' (logical)
        # String concat should use concat() function directly
        result = []
        i = 0
        in_string = False
        string_char = None
        
        while i < len(expression):
            char = expression[i]
            
            if char in ('"', "'") and (i == 0 or expression[i-1] != '\\'):
                if not in_string:
                    in_string = True
                    string_char = char
                elif char == string_char:
                    in_string = False
                    string_char = None
                result.append(char)
                i += 1
                continue
            
            if in_string:
                result.append(char)
                i += 1
                continue
            
            # Convert || to 'or'
            if char == '|' and i + 1 < len(expression) and expression[i + 1] == '|':
                result.append(' or ')
                i += 2
                continue
            
            result.append(char)
            i += 1
        
        return ''.join(result)
    
    def _convert_variables_to_template(
        self, 
        expression: str, 
        available_columns: Optional[List[str]] = None
    ) -> str:
        """Convert bare variable names to ${column} syntax."""
        if not expression:
            return expression
        
        # Build set of function names to exclude
        function_names = set(self.functions.keys())
        exclude_set = self.RESERVED_WORDS | function_names
        
        # Add expr-eval function names
        exclude_set.update(self.EXPR_EVAL_FUNCTION_MAP.keys())
        
        column_set = set(available_columns) if available_columns else None
        
        result = []
        i = 0
        in_string = False
        string_char = None
        
        while i < len(expression):
            char = expression[i]
            
            # Handle string literals
            if char in ('"', "'") and (i == 0 or expression[i-1] != '\\'):
                if not in_string:
                    in_string = True
                    string_char = char
                elif char == string_char:
                    in_string = False
                    string_char = None
                result.append(char)
                i += 1
                continue
            
            if in_string:
                result.append(char)
                i += 1
                continue
            
            # Check for identifier
            if char.isalpha() or char == '_':
                # Extract full identifier
                j = i
                while j < len(expression) and (expression[j].isalnum() or expression[j] == '_'):
                    j += 1
                identifier = expression[i:j]
                
                # Check if it's followed by ( - means it's a function call
                next_non_space = j
                while next_non_space < len(expression) and expression[next_non_space] == ' ':
                    next_non_space += 1
                is_function_call = next_non_space < len(expression) and expression[next_non_space] == '('
                
                # Convert if it's a column reference (not a function or reserved word)
                if not is_function_call and identifier not in exclude_set:
                    if column_set is None or identifier in column_set:
                        result.append(f'${{{identifier}}}')
                    else:
                        result.append(identifier)
                else:
                    result.append(identifier)
                i = j
            else:
                result.append(char)
                i += 1
        
        return ''.join(result)
    
    def detect_syntax(self, expression: str) -> str:
        """
        Detect whether expression uses template or expr-eval syntax.
        
        Returns:
            'template' if expression uses ${column} syntax
            'expr-eval' if expression uses bare variable names
        """
        if '${' in expression:
            return 'template'
        return 'expr-eval'
    
    def normalize_expression(
        self, 
        expression: str, 
        syntax: str = 'auto',
        available_columns: Optional[List[str]] = None
    ) -> str:
        """
        Normalize expression to template syntax.
        
        Args:
            expression: Expression string
            syntax: 'template', 'expr-eval', or 'auto'
            available_columns: Column names for expr-eval conversion
            
        Returns:
            Expression in template syntax
        """
        if syntax == 'auto':
            syntax = self.detect_syntax(expression)
        
        if syntax == 'expr-eval':
            return self.convert_expr_eval_to_template(expression, available_columns)
        
        return expression
    
    def _build_function_registry(self) -> Dict[str, Callable]:
        """Build the registry of safe functions available in expressions."""
        return {
            # String functions (comprehensive for expr-eval custom function compatibility)
            'concat': self._fn_concat,
            'upper': lambda s: str(s).upper() if s is not None else None,
            'lower': lambda s: str(s).lower() if s is not None else None,
            'capitalize': lambda s: str(s).capitalize() if s is not None else None,
            'title': lambda s: str(s).title() if s is not None else None,
            'trim': lambda s: str(s).strip() if s is not None else None,
            'ltrim': lambda s: str(s).lstrip() if s is not None else None,
            'rtrim': lambda s: str(s).rstrip() if s is not None else None,
            'strip': lambda s: str(s).strip() if s is not None else None,  # alias
            'substring': self._fn_substring,
            'substr': self._fn_substring,  # alias
            'slice': self._fn_substring,  # JS-style alias
            'replace': lambda s, old, new: str(s).replace(old, new) if s is not None else None,
            'replaceAll': lambda s, old, new: str(s).replace(old, new) if s is not None else None,  # JS alias
            'split': lambda s, sep=',': str(s).split(sep) if s is not None else None,
            'join': lambda lst, sep=',': sep.join(str(x) for x in lst) if lst is not None else None,
            'length': lambda s: len(str(s)) if s is not None else None,
            'len': lambda s: len(str(s)) if s is not None else None,  # alias
            'left': lambda s, n: str(s)[:int(n)] if s is not None else None,
            'right': lambda s, n: str(s)[-int(n):] if s is not None else None,
            'mid': lambda s, start, length: str(s)[int(start):int(start)+int(length)] if s is not None else None,
            'pad_left': lambda s, n, c=' ': str(s).rjust(int(n), str(c)[0]) if s is not None else None,
            'pad_right': lambda s, n, c=' ': str(s).ljust(int(n), str(c)[0]) if s is not None else None,
            'padStart': lambda s, n, c=' ': str(s).rjust(int(n), str(c)[0]) if s is not None else None,  # JS alias
            'padEnd': lambda s, n, c=' ': str(s).ljust(int(n), str(c)[0]) if s is not None else None,  # JS alias
            'repeat': lambda s, n: str(s) * int(n) if s is not None else None,
            'reverse': lambda s: str(s)[::-1] if s is not None else None,
            'contains': lambda s, sub: sub in str(s) if s is not None and sub is not None else False,
            'includes': lambda s, sub: sub in str(s) if s is not None and sub is not None else False,  # JS alias
            'starts_with': lambda s, prefix: str(s).startswith(prefix) if s is not None else False,
            'startsWith': lambda s, prefix: str(s).startswith(prefix) if s is not None else False,  # JS alias
            'ends_with': lambda s, suffix: str(s).endswith(suffix) if s is not None else False,
            'endsWith': lambda s, suffix: str(s).endswith(suffix) if s is not None else False,  # JS alias
            'indexOf': lambda s, sub: str(s).find(sub) if s is not None and sub is not None else -1,
            'lastIndexOf': lambda s, sub: str(s).rfind(sub) if s is not None and sub is not None else -1,
            'charAt': lambda s, i: str(s)[int(i)] if s is not None and 0 <= int(i) < len(str(s)) else '',
            'charCodeAt': lambda s, i: ord(str(s)[int(i)]) if s is not None and 0 <= int(i) < len(str(s)) else None,
            'fromCharCode': lambda *codes: ''.join(chr(int(c)) for c in codes),
            'match': self._fn_regex_match,
            'test': lambda s, pattern: bool(re.search(pattern, str(s))) if s is not None else False,
            'regex_match': self._fn_regex_match,
            'regex_replace': self._fn_regex_replace,
            'format': self._fn_format,
            'sprintf': self._fn_format,  # alias
            'isNumeric': lambda s: str(s).replace('.', '', 1).replace('-', '', 1).isdigit() if s is not None else False,
            'isAlpha': lambda s: str(s).isalpha() if s is not None else False,
            'isAlphaNumeric': lambda s: str(s).isalnum() if s is not None else False,
            'isEmpty': lambda s: s is None or str(s).strip() == '',
            'isNotEmpty': lambda s: s is not None and str(s).strip() != '',
            'isBlank': lambda s: s is None or str(s).strip() == '',
            'isNotBlank': lambda s: s is not None and str(s).strip() != '',
            'defaultIfEmpty': lambda s, default: default if s is None or str(s).strip() == '' else s,
            'defaultIfNull': lambda s, default: default if s is None else s,
            
            # Numeric functions
            'round': lambda x, n=0: round(float(x), int(n)) if x is not None else None,
            'floor': lambda x: math.floor(float(x)) if x is not None else None,
            'ceil': lambda x: math.ceil(float(x)) if x is not None else None,
            'ceiling': lambda x: math.ceil(float(x)) if x is not None else None,  # alias
            'abs': lambda x: abs(float(x)) if x is not None else None,
            'min': lambda *args: min(x for x in args if x is not None) if any(x is not None for x in args) else None,
            'max': lambda *args: max(x for x in args if x is not None) if any(x is not None for x in args) else None,
            'sum': lambda *args: sum(float(x) for x in args if x is not None),
            'avg': self._fn_avg,
