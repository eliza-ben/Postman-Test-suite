class ColumnExpression(BaseModel):
    """
    Configuration for a single column expression.
    
    Defines how to compute the value for a target column using an expression
    that can reference source columns and apply various operations.
    
    Examples:
    ---------
    Simple column reference:
        {
            "target_column": "name",
            "expression": "${source_name}",
            "default": "N/A"
        }
    
    Arithmetic calculation:
        {
            "target_column": "total",
            "expression": "${quantity} * ${price}",
            "default": 0
        }
    
    String concatenation:
        {
            "target_column": "full_name",
            "expression": "concat(${first_name}, ' ', ${last_name})",
            "default": "Unknown"
        }
    
    Conditional expression:
        {
            "target_column": "status",
            "expression": "if(${amount} > 1000, 'Premium', 'Standard')",
            "default": "Unknown"
        }
    """
    target_column: str = Field(..., description="Target column name in the output")
    expression: str = Field(..., description="Expression to evaluate. Use ${column_name} or bare variable names (expr-eval syntax)")
    default: Optional[Any] = Field(default=None, description="Default value if expression evaluates to null or fails")
    data_type: Optional[str] = Field(default=None, description="Expected data type: string, int, float, decimal, boolean, date, datetime")
    syntax: Optional[str] = Field(default="auto", description="Expression syntax: 'template' (${col}), 'expr-eval' (bare names), or 'auto' (detect)")
    
    class Config:
        schema_extra = {
            "example": {
                "target_column": "total_amount",
                "expression": "${quantity} * ${unit_price}",
                "default": 0,
                "data_type": "decimal"
            }
        }


class ExpressionConfig(BaseModel):
    """
    Complete expression evaluation configuration.
    
    Defines all column expressions to apply during ETL processing.
    This configuration can be used across all ETL services for consistent
    expression evaluation behavior.
    
    Examples:
    ---------
    Basic expressions:
        {
            "expressions": [
                {"target_column": "id", "expression": "${source_id}"},
                {"target_column": "name", "expression": "upper(${source_name})"},
                {"target_column": "total", "expression": "${qty} * ${price}", "default": 0}
            ],
            "preserve_unmapped": false
        }
    
    With pass-through of unmapped columns:
        {
            "expressions": [...],
            "preserve_unmapped": true
        }
    """
    expressions: List[ColumnExpression] = Field(..., description="List of column expressions to evaluate")
    preserve_unmapped: bool = Field(default=False, description="If true, preserve source columns not in expressions")
    
    class Config:
        schema_extra = {
            "example": {
                "expressions": [
                    {"target_column": "full_name", "expression": "concat(${first_name}, ' ', ${last_name})", "default": "Unknown"},
                    {"target_column": "total", "expression": "${quantity} * ${price}", "default": 0}
                ],
                "preserve_unmapped": False
            }
        }


